# Copy this file to a private shell snippet, fill in your real DeepSeek key, then run:
#   source experiments/deepseek_replication.env
#   ./experiments/run_frontier_toolsandbox_replication.sh
#
# Do not commit or share real API keys.

export FRONTIER_BASE_URL="https://api.deepseek.com/v1"

# Recommended first run: DeepSeek's OpenAI-compatible chat model.
# You can also try "deepseek-reasoner", but it is slower/costlier and has different
# reasoning-output behavior.
export FRONTIER_MODEL="deepseek-chat"

export FRONTIER_API_KEY="replace-with-your-private-deepseek-api-key"

# 0 means run the full selected ToolSandbox suite.
export MAX_SCENARIOS="0"

export OUTPUT_ROOT="results/frontier_toolsandbox_replication_deepseek"
export CONDA_BIN="${CONDA_BIN:-conda}"
export CONDA_ENV_PATH="${CONDA_ENV_PATH:-pctu-sim}"
