# Copy this file to a private shell snippet and fill in real credentials before running
# `experiments/run_frontier_toolsandbox_replication.sh`.
#
# Do not commit or share real API keys.

export FRONTIER_BASE_URL="https://api.example.com/v1"
export FRONTIER_MODEL="frontier-model-name"
export FRONTIER_API_KEY="replace-with-private-key"

# 0 means run the full selected ToolSandbox suite.
export MAX_SCENARIOS="0"

# Optional overrides.
export OUTPUT_ROOT="results/frontier_toolsandbox_replication"
export CONDA_BIN="${CONDA_BIN:-conda}"
export CONDA_ENV_PATH="${CONDA_ENV_PATH:-pctu-sim}"
